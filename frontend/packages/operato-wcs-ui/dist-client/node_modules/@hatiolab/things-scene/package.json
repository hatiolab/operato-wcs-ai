{
  "name": "@hatiolab/things-scene",
  "version": "3.0.12",
  "description": "2D graphic library",
  "main": "src/index.js",
  "module": "things-scene.mjs",
  "jsnext:main": "things-scene.mjs",
  "browser": "things-scene.mjs",
  "types": "things-scene.d.ts",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hatiolab/things-scene.git"
  },
  "keywords": [
    "2D",
    "graphic",
    "library",
    "canvas"
  ],
  "scripts": {
    "test": "mocha --require should --require @babel/register test/**/test-*.js",
    "test:case": "mocha --require should --require @babel/register",
    "serve": "things-factory",
    "serve:dev": "things-factory-dev",
    "serve:simple-http-server": "webpack-dev-server --config webpack.config.dev.js --hot --inline --host 0.0.0.0",
    "build": "webpack && rollup -c",
    "build:client": "npm run clean:client && webpack --config node_modules/@things-factory/shell/webpack.config.js",
    "clean:client": "rm -rf dist-client",
    "prepublish": "webpack && rollup -c",
    "migration": "things-factory-migration",
    "prettify": "prettier --write \"{src,samples,test}/**/*.{js,css,html}\""
  },
  "author": "heartyoh@hatiolab.com",
  "license": "SEE LICENSE IN http://things-scene.hatiolab.com/EULA/",
  "devDependencies": {
    "@babel/cli": "^7.17.6",
    "@babel/core": "^7.17.9",
    "@babel/plugin-proposal-class-properties": "^7.16.7",
    "@babel/plugin-proposal-decorators": "^7.17.9",
    "@babel/plugin-proposal-object-rest-spread": "^7.17.3",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/preset-env": "^7.16.11",
    "@babel/register": "^7.17.7",
    "@rollup/plugin-commonjs": "^21.0.3",
    "@rollup/plugin-node-resolve": "^13.2.0",
    "@things-factory/builder": "^5.0.0-alpha.49",
    "@things-factory/operato-board": "^5.0.0-alpha.49",
    "atob": "^2.1.2",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^27.5.1",
    "babel-loader": "^8.2.4",
    "chai": "^4.3.6",
    "chai-dom": "^1.11.0",
    "gulp": "^4.0.0",
    "gulp-header-license": "^1.0.9",
    "mocha": "^9.2.2",
    "prettier": "^2.6.2",
    "rollup": "^2.70.1",
    "rollup-plugin-babel": "^4.3.2",
    "rollup-plugin-input-array": "^1.0.1",
    "rollup-plugin-terser": "^7.0.2",
    "should": "^13.2.3",
    "ts-node": "^10.7.0",
    "tsconfig-paths": "^3.14.1",
    "typescript": "^4.6.3",
    "webpack": "^5.72.0",
    "webpack-cleanup-plugin": "^0.5.1",
    "webpack-cli": "^4.9.2",
    "webpack-dev-server": "^4.8.1",
    "workbox-webpack-plugin": "^6.5.3"
  },
  "bugs": {
    "url": "https://github.com/hatiolab/things-scene/issues"
  },
  "homepage": "https://github.com/hatiolab/things-scene#readme",
  "dependencies": {
    "core-js": "^3.21.1",
    "lodash": "^4.17.20"
  },
  "optionalDependencies": {
    "canvas": "^2.9.1"
  }
}
