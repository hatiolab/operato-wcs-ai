{
  "name": "@things-factory/operato-wcs-ui",
  "version": "0.0.1",
  "main": "dist-server/index.js",
  "browser": "client/index.js",
  "things-factory": true,
  "license": "MIT",
  "author": "heartyoh",
  "description": "Operato WCS UI",
  "publishConfig": {
    "access": "public",
    "@things-factory:registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hatiolab/things-factory.git",
    "directory": "packages/operato-wcs-ui"
  },
  "scripts": {
    "serve": "things-factory operato-wcs-ui",
    "serve:dev": "npm run build:server && things-factory-dev operato-wcs-ui",
    "build": "tsc --p tsconfig.json",
    "build:client": "npm run clean:client && webpack --config ../../node_modules/@things-factory/builder/webpack.config.js",
    "build:server": "npm run clean:server && tsc",
    "clean:server": "rm -rf dist-server",
    "clean:client": "rm -rf dist-client",
    "clean": "npm run clean:server && npm run clean:client",
    "migration": "npm run build:server && things-factory-migration",
    "migration:privileges": "npm run build:server && things-factory-migration-privileges",
    "migration:create": "node ../../node_modules/typeorm/cli.js migration:create -d ./server/migrations",
    "migration:generate": "node ../../node_modules/typeorm/cli.js migration:generate",
    "migration:run": "node ../../node_modules/typeorm/cli.js migration:run",
    "migration:revert": "node ../../node_modules/typeorm/cli.js migration:revert",
    "stop:dev": "kill $(lsof -t -i:3000,3001)",
    "stop": "things-factory-stop operato-wcs-ui",
    "docker": "things-factory-dockerize hatiolab/operato-wcs-ui:latest",
    "docker:run": "docker run -it -p 4000:3000 hatiolab/operato-wcs-ui:latest"
  },
  "dependencies": {
    "@operato/board": "^1.0.0-beta.4",
    "@operato/data-grist": "^1.0.0-beta.10",
    "@operato/font": "^1.0.0-beta.4",
    "@operato/ghost-print": "^1.0.0-beta.4",
    "@operato/graphql": "^1.0.0-beta.4",
    "@operato/i18n": "^1.0.0-beta.4",
    "@operato/layout": "^1.0.0-beta.4",
    "@operato/popup": "^1.0.0-beta.4",
    "@operato/pull-to-refresh": "^1.0.0-beta.4",
    "@operato/shell": "^1.0.0-beta.4",
    "@operato/styles": "^1.0.0-beta.4",
    "@operato/utils": "^1.0.0-beta.10",
    "@things-factory/api": "^5.0.0-alpha.36",
    "@things-factory/apptool-ui": "^5.0.0-alpha.36",
    "@things-factory/attachment-base": "^5.0.0-alpha.36",
    "@things-factory/attachment-ui": "^5.0.0-alpha.36",
    "@things-factory/auth-ui": "^5.0.0-alpha.36",
    "@things-factory/barcode-ui": "^5.0.0-alpha.36",
    "@things-factory/barcode-base": "^5.0.0-alpha.36",
    "@things-factory/board-service": "^5.0.0-alpha.36",
    "@things-factory/board-ui": "^5.0.0-alpha.36",
    "@things-factory/code-ui": "^5.0.0-alpha.36",
    "@things-factory/context-ui": "^5.0.0-alpha.36",
    "@things-factory/dashboard": "^5.0.0-alpha.36",
    "@things-factory/export-ui": "^5.0.0-alpha.36",
    "@things-factory/export-ui-excel": "^5.0.0-alpha.36",
    "@things-factory/grist-ui": "^5.0.0-alpha.36",
    "@things-factory/help": "^5.0.0-alpha.36",
    "@things-factory/integration-ui": "^5.0.0-alpha.36",
    "@things-factory/lite-menu": "^5.0.0-alpha.36",
    "@things-factory/more-ui": "^5.0.0-alpha.36",
    "@things-factory/notification": "^5.0.0-alpha.36",
    "@things-factory/print-ui": "^5.0.0-alpha.36",
    "@things-factory/resource-ui": "^5.0.0-alpha.36",
    "@things-factory/routing-base": "^5.0.0-alpha.36",
    "@things-factory/setting-base": "^5.0.0-alpha.36",
    "@things-factory/setting-ui": "^5.0.0-alpha.36",
    "@things-factory/shell": "^5.0.0-alpha.36",
    "@things-factory/system-ui": "^5.0.0-alpha.36",
    "@things-factory/operatofill": "^0.0.1",
    "@things-factory/metapage": "^0.0.1",
    "@things-factory/operato-wcs-system-ui": "^0.0.1"
  },
  "devDependencies": {
    "@things-factory/builder": "^5.0.0-alpha.35",
    "@types/node": "17.0.21",
    "plop": "^3.0.5"
  }
}